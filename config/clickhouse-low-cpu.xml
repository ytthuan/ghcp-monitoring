<?xml version="1.0"?>
<clickhouse>
    <!-- Local dashboard profile: keep user telemetry, drop noisy self-observability logs. -->
    <logger>
        <level>warning</level>
    </logger>

    <trace_log remove="1"/>
    <query_log remove="1"/>
    <query_thread_log remove="1"/>
    <query_views_log remove="1"/>
    <query_metric_log remove="1"/>
    <metric_log remove="1"/>
    <asynchronous_metric_log remove="1"/>
    <text_log remove="1"/>
    <part_log remove="1"/>
    <processors_profile_log remove="1"/>
    <asynchronous_insert_log remove="1"/>
    <opentelemetry_span_log remove="1"/>
</clickhouse>
