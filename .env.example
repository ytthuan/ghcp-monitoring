# Copy this file to .env when you need local overrides.
# Never commit real secrets in .env.

# Compose port bindings. Defaults bind to 127.0.0.1 (loopback). To widen
# dashboard or OTel collector exposure to your LAN, see the new
# DASHBOARD_BIND_HOST / OTEL_BIND_HOST vars further down. ClickHouse
# stays loopback-only by design (ADR-0004).
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133

# Bind addresses for the loopback-default services. Defaults to 127.0.0.1.
# Set to 0.0.0.0 (or a specific NIC IP, e.g. 192.168.0.100) to allow access
# from other devices on your LAN. WHEN YOU DO THIS, you MUST also rotate
# DASHBOARD_PASSWORD below to a strong random value — the OTel collector
# has no auth, and the dashboard's only protection is Basic Auth.
# ClickHouse stays loopback-only by design.
OTEL_BIND_HOST=127.0.0.1

# ClickHouse — OLAP store backing the new dashboard. No host port; lives on the
# docker network at clickhouse:8123 / clickhouse:9000.
CLICKHOUSE_USER=copilot
CLICKHOUSE_PASSWORD=change-me-strong-password
CLICKHOUSE_DB=copilot_telemetry

# How long ClickHouse keeps Copilot telemetry rows. Bounded retention is a
# Security & Audit gate — do not remove. Used both by the OTel exporter TTL
# and by retention pruning logic in the dashboard.
RETENTION_DAYS=90

# New TanStack dashboard. Loopback bind only by default (ADR-0004); set
# DASHBOARD_BIND_HOST=0.0.0.0 to expose on the LAN (rotate DASHBOARD_PASSWORD!).
DASHBOARD_PORT=6969
DASHBOARD_BIND_HOST=127.0.0.1

# Initial dashboard filter state for fresh sessions (no URL query params).
# The user can still pick any range/granularity from the FilterBar — these
# just change the empty-URL defaults and the "reset filters" baseline.
# Allowed ranges: 1h, 6h, 24h, 7d, 30d (NOT "custom" — that requires from/to).
# Allowed granularities: 5m, 1h, 1d.
DASHBOARD_DEFAULT_RANGE=7d
DASHBOARD_DEFAULT_GRANULARITY=1h

# Copilot client settings for terminal sessions.
# Docker Compose reads .env for container configuration, but your current shell
# does not. Run `source scripts/setup-terminal.sh` on Bash/Zsh/Git Bash or
# `.\scripts\setup-terminal.ps1` on Windows PowerShell before starting Copilot
# CLI commands from a terminal.
# Use OTLP HTTP on port 4318 here; port 4317 is gRPC-only. Do not add a
# trailing slash to OTEL_EXPORTER_OTLP_ENDPOINT.
# Keep COPILOT_OTEL_CAPTURE_CONTENT=false unless you are debugging in a
# trusted, scoped session — content can include prompts, code, file paths,
# and secrets. The collector strips auth headers but does NOT double-redact
# GenAI content by default.
COPILOT_OTEL_ENABLED=true
COPILOT_OTEL_CAPTURE_CONTENT=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=github-copilot

# Optional future cloud exporter setting. Leave blank for local-only telemetry.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Dashboard Basic Auth (loopback-only). Both the Docker dashboard and local
# `pnpm --dir apps/dashboard dev` read these values from the repo-root `.env`.
# The example keeps admin/admin for first boot only; rotate before LAN bind.
# If you change these values for Docker, rebuild with
# `docker compose up -d --build dashboard`. Browsers cache 401s — open a
# private window after rotating.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin
